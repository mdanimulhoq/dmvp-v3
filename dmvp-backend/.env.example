# ==============================
# DMVP Backend Environment File
# ==============================
# Copy this file to ".env" and replace all placeholder values.
# Development may run on HTTP, but production must be deployed behind TLS 1.3.

# ------------------------------
# Core Application
# ------------------------------
NODE_ENV=development
PORT=3000
APP_NAME=dmvp-backend
APP_VERSION=3.0.0
API_BASE_PATH=/api/v1

# Public base URL of this backend (used in references, links, and metadata)
APP_BASE_URL=http://localhost:3000

# Frontend / Android app origins for CORS
# Comma-separated list. Example:
# CORS_ORIGINS=http://localhost:5173,http://10.0.2.2:3000
CORS_ORIGINS=*

# ------------------------------
# Database
# ------------------------------
# PostgreSQL connection string
# Example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dmvp?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dmvp?schema=public

# Direct URL is optional but recommended for Prisma migration/admin operations
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/dmvp?schema=public

# ------------------------------
# Authentication / JWT
# ------------------------------
# Generate a strong random secret in production:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_very_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=dmvp-backend
JWT_AUDIENCE=dmvp-clients

# Optional admin bootstrap credentials (if later used by device/admin flows)
ADMIN_EMAIL=admin@dmvp.local
ADMIN_PASSWORD=change_this_admin_password

# ------------------------------
# Request Security / Replay Protection
# ------------------------------
# Nonce expiry window in seconds for signed requests
NONCE_TTL_SECONDS=300

# Allowed clock drift for timestamp validation in seconds
REQUEST_TIME_SKEW_SECONDS=300

# Idempotency key retention window in hours
IDEMPOTENCY_TTL_HOURS=24

# ------------------------------
# Rate Limiting
# ------------------------------
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# Optional stricter limits for sensitive endpoints
AUTH_RATE_LIMIT_MAX_REQUESTS=20
VERIFY_RATE_LIMIT_MAX_REQUESTS=60
REGISTER_RATE_LIMIT_MAX_REQUESTS=30

# ------------------------------
# Cryptography / Protocol
# ------------------------------
DMVP_PROTOCOL_VERSION=dmvp-v3.0.0
VERIFICATION_POLICY_VERSION=policy-v3.0.0
SIGNATURE_ALGORITHM=SHA256withECDSA

# Server-side audit reference prefix for evidence chains
AUDIT_REFERENCE_PREFIX=DMVP-AUDIT

# If trusted timestamp integration is added later, keep reference namespace here
TIMESTAMP_PROVIDER_NAME=internal-dev
TIMESTAMP_PROVIDER_URL=

# ------------------------------
# Device Trust / Attestation
# ------------------------------
# Android attestation verification mode:
# off | basic | strict
ANDROID_ATTESTATION_MODE=basic

# Whether attestation is required for Tier A classification
REQUIRE_VALID_ATTESTATION_FOR_TIER_A=true

# Future Android attestation verifier settings placeholders
ANDROID_KEYSTORE_CHALLENGE_BYTES=32
ANDROID_ATTESTATION_MAX_AGE_DAYS=30

# ------------------------------
# Upload / Request Limits
# ------------------------------
# Zero-storage core means original media is never persisted.
# These limits are for transient in-memory processing only.
MAX_JSON_BODY_MB=2
MAX_UPLOAD_MB=100
MAX_VIDEO_DURATION_SECONDS=300
MAX_IMAGE_PIXELS=40000000

# Multer temp mode:
# memory | disk
UPLOAD_STORAGE_MODE=memory

# Temporary directory if disk mode is ever enabled
UPLOAD_TEMP_DIR=./tmp/uploads

# ------------------------------
# Search / Similarity Thresholds
# ------------------------------
# Exact SHA-256 match always takes priority.
# Thresholds below are used for candidate filtering / reranking.
PHASH_STRONG_THRESHOLD=8
PHASH_PROBABLE_THRESHOLD=16
PHASH_WEAK_THRESHOLD=24

ROBUST_SIMILARITY_STRONG=0.90
ROBUST_SIMILARITY_PROBABLE=0.75
ROBUST_SIMILARITY_WEAK=0.60

SEARCH_CANDIDATE_LIMIT=100
SEARCH_RERANK_LIMIT=20

# ------------------------------
# Logging / Audit
# ------------------------------
LOG_LEVEL=info
LOG_DIR=./logs
LOG_TO_CONSOLE=true

# Audit log file names
AUDIT_LOG_FILE=audit.log
APP_LOG_FILE=application.log
ERROR_LOG_FILE=error.log

# Append-only audit mode
AUDIT_APPEND_ONLY=true

# ------------------------------
# Optional Redis (future-proof)
# ------------------------------
# Leave empty if not used. Current implementation can fall back to DB-only.
REDIS_URL=
USE_REDIS_FOR_NONCE_CACHE=false

# ------------------------------
# Email / Notification (optional, not required)
# ------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@dmvp.local

# ------------------------------
# Development Flags
# ------------------------------
ENABLE_SWAGGER=false
ENABLE_REQUEST_LOGGING=true
ENABLE_STACK_TRACES=true
TRUST_PROXY=false

# ------------------------------
# Production Notes
# ------------------------------
# For production:
# - Set NODE_ENV=production
# - Use a strong JWT_SECRET
# - Set CORS_ORIGINS to explicit origins, never "*"
# - Terminate TLS 1.3 at reverse proxy/load balancer
# - Set TRUST_PROXY=true if behind Nginx/Cloudflare/Load Balancer
# - Disable ENABLE_STACK_TRACES
# - Use managed PostgreSQL backups
