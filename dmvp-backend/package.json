{
  "name": "dmvp-backend",
  "version": "3.0.0",
  "description": "Decentralized Media Verification Protocol (DMVP) v3.0 Backend — Zero-storage evidence registration, multi-axis verification, and cryptographic provenance for media authenticity. Stores only cryptographic proofs (SHA-256, robust fingerprints, ECDSA signatures), never original media.",
  "author": "DMVP Project Contributors",
  "license": "Apache-2.0",
  "main": "src/app.js",
  "engines": {
    "node": "22.x",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "install:ci": "npm install --legacy-peer-deps",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push --accept-data-loss",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "build": "npm run db:generate && npm run db:push",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "@ipld/dag-cbor": "^10.0.1",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "c2pa-node": "^0.5.26",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "file-type": "^16.5.4",
    "google-auth-library": "^10.9.0",
    "hash-wasm": "^4.12.0",
    "helmet": "^8.0.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multiformats": "^14.0.4",
    "node-rsa": "^1.1.1",
    "prisma": "5.22.0",
    "resend": "^6.17.2",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "ulid": "^3.0.2",
    "uuid": "^10.0.0",
    "winston": "^3.15.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  },
  "keywords": [
    "dmvp",
    "media-verification",
    "provenance",
    "cryptography",
    "ecdsa",
    "sha256",
    "perceptual-hash",
    "forensics",
    "zero-storage",
    "content-authenticity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dmvp-project/dmvp-backend.git"
  },
  "bugs": {
    "url": "https://github.com/dmvp-project/dmvp-backend/issues"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js"
    ],
    "coverageDirectory": "coverage"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules",
      "coverage",
      "logs"
    ],
    "delay": "500"
  }
}
